{
  "name": "sherwood-subgraph",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph codegen && graph build",
    "deploy": "graph deploy sherwood-subgraph",
    "create-local": "graph create --node http://localhost:8020/ sherwood-subgraph",
    "remove-local": "graph remove --node http://localhost:8020/ sherwood-subgraph",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 sherwood-subgraph"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.97.1",
    "@graphprotocol/graph-ts": "^0.36.0"
  }
}
